datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Rol {
  ADMINISTRADOR
  CAJERO
  EMPLEADO
}

enum Estado {
  ACTIVO
  INACTIVO
}

enum TipoMovimiento {
  INGRESO
  EGRESO
}

model Usuario {
  id             String          @id @default(uuid())
  email          String          @unique
  contrasena     String
  nombre         String
  rol            Rol             @default(EMPLEADO)
  estado         Estado          @default(ACTIVO)
  fechaCreacion  DateTime        @default(now())
  fechaEdicion   DateTime        @updatedAt
  tokensRefresco TokenRefresco[]
  ventas         Venta[]
  compras        Compra[]
  cajas          Caja[]
}

model TokenRefresco {
  id              String   @id @default(uuid())
  token           String   @unique
  usuarioId       String
  usuario         Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  fechaExpiracion DateTime
  fechaCreacion   DateTime @default(now())
}

model Categoria {
  id            String     @id @default(uuid())
  nombre        String     @unique
  descripcion   String?
  productos     Producto[]
  fechaCreacion DateTime   @default(now())
  fechaEdicion  DateTime   @updatedAt
}

model Marca {
  id            String     @id @default(uuid())
  nombre        String     @unique
  productos     Producto[]
  fechaCreacion DateTime   @default(now())
  fechaEdicion  DateTime   @updatedAt
}

model Proveedor {
  id            String     @id @default(uuid())
  nombre        String
  cuit          String?    @unique
  telefono      String?
  email         String?
  direccion     String?
  observaciones String?
  productos     Producto[]
  compras       Compra[]
  fechaCreacion DateTime   @default(now())
  fechaEdicion  DateTime   @updatedAt
}

model Cliente {
  id            String     @id @default(uuid())
  nombre        String
  apellido      String
  dni           String?    @unique
  telefono      String?
  email         String?
  direccion     String?
  observaciones String?
  saldoDeuda    Decimal    @default(0.00) @db.Decimal(12, 2)
  ventas        Venta[]
  fechaCreacion DateTime   @default(now())
  fechaEdicion  DateTime   @updatedAt
}

model Producto {
  id             String          @id @default(uuid())
  nombre         String
  descripcion    String?
  sku            String?         @unique
  codigoBarras   String?         @unique
  precioCompra   Decimal         @db.Decimal(12, 2)
  precioVenta    Decimal         @db.Decimal(12, 2)
  margenGanancia Decimal         @db.Decimal(5, 2)
  stock          Int             @default(0)
  stockMinimo    Int             @default(0)
  estado         Estado          @default(ACTIVO)
  fechaVence     DateTime?
  categoriaId    String
  categoria      Categoria       @relation(fields: [categoriaId], references: [id])
  marcaId        String
  marca          Marca           @relation(fields: [marcaId], references: [id])
  proveedorId    String
  proveedor      Proveedor       @relation(fields: [proveedorId], references: [id])
  imagenUrl      String?
  detallesVenta  DetalleVenta[]
  detallesCompra DetalleCompra[]
  fechaCreacion  DateTime        @default(now())
  fechaEdicion   DateTime        @updatedAt
}

model Venta {
  id             String         @id @default(uuid())
  numeroTicket   String         @unique
  subtotal       Decimal        @db.Decimal(12, 2)
  impuesto       Decimal        @db.Decimal(12, 2)
  descuento      Decimal        @db.Decimal(12, 2) @default(0.00)
  total          Decimal        @db.Decimal(12, 2)
  montoRecibido  Decimal        @db.Decimal(12, 2)
  montoCambio    Decimal        @db.Decimal(12, 2)
  clienteId      String?
  cliente        Cliente?       @relation(fields: [clienteId], references: [id])
  usuarioId      String
  usuario        Usuario        @relation(fields: [usuarioId], references: [id])
  detalles       DetalleVenta[]
  cajaId         String?
  caja           Caja?          @relation(fields: [cajaId], references: [id])
  fechaCreacion  DateTime       @default(now())
}

model DetalleVenta {
  id           String   @id @default(uuid())
  ventaId      String
  venta        Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)
  productoId   String
  producto     Producto @relation(fields: [productoId], references: [id])
  cantidad     Int
  precioUnidad Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
}

model Compra {
  id            String          @id @default(uuid())
  total         Decimal         @db.Decimal(12, 2)
  proveedorId   String
  proveedor     Proveedor       @relation(fields: [proveedorId], references: [id])
  usuarioId     String
  usuario       Usuario         @relation(fields: [usuarioId], references: [id])
  detalles      DetalleCompra[]
  fechaCreacion DateTime        @default(now())
}

model DetalleCompra {
  id           String   @id @default(uuid())
  compraId     String
  compra       Compra   @relation(fields: [compraId], references: [id], onDelete: Cascade)
  productoId   String
  producto     Producto @relation(fields: [productoId], references: [id])
  cantidad     Int
  precioUnidad Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
}

model Caja {
  id             String           @id @default(uuid())
  usuarioId      String
  usuario        Usuario          @relation(fields: [usuarioId], references: [id])
  fechaApertura  DateTime         @default(now())
  fechaCierre    DateTime?
  saldoApertura  Decimal          @db.Decimal(12, 2)
  saldoCierre    Decimal?         @db.Decimal(12, 2)
  saldoEsperado  Decimal?         @db.Decimal(12, 2)
  diferencia     Decimal?         @db.Decimal(12, 2)
  ventas         Venta[]
  movimientos    MovimientoCaja[]
  fechaCreacion  DateTime         @default(now())
  fechaEdicion   DateTime         @updatedAt
}

model MovimientoCaja {
  id            String         @id @default(uuid())
  cajaId        String
  caja          Caja           @relation(fields: [cajaId], references: [id], onDelete: Cascade)
  tipo          TipoMovimiento
  monto         Decimal        @db.Decimal(12, 2)
  descripcion   String
  fechaCreacion DateTime       @default(now())
}

model Configuracion {
  id             String  @id @default(uuid())
  nombreNegocio  String  @default("StockFlow Kiosco")
  logoUrl        String?
  direccion      String?
  telefono       String?
  email          String?
  simboloMoneda  String  @default("$")
  codigoMoneda   String  @default("ARS")
  porcentajeIVA  Decimal @default(0.00) @db.Decimal(5, 2)
}
