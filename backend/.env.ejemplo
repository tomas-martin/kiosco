PORT=4000
NODE_ENV=development

# Base de Datos (Supabase o PostgreSQL Local)
DATABASE_URL="postgresql://usuario:contrasena@localhost:5432/nombre_db?schema=public"

# Seguridad y Tokens JWT
JWT_SECRET="reemplazar_con_una_cadena_larga_y_segura"
JWT_REFRESH_SECRET="reemplazar_con_otra_cadena_larga_y_segura"

# Tiempo de expiracion de tokens
JWT_EXPIRACION_ACCESO="15m"
JWT_EXPIRACION_REFRESCO="7d"

# IA Local (Ollama)
OLLAMA_URL="http://localhost:11434"

# Almacenamiento Cloudinary
CLOUDINARY_CLOUD_NAME="tu_cloud_name"
CLOUDINARY_API_KEY="tu_api_key"
CLOUDINARY_API_SECRET="tu_api_secret"

# Correo (Para recuperacion de contrasena)
CORREO_HOST="smtp.gmail.com"
CORREO_PORT=587
CORREO_USUARIO="tu_correo@gmail.com"
CORREO_CONTRASENA="tu_contrasena_de_aplicacion"
CORREO_DESDE="StockFlow <no-reply@stockflow.com>"
